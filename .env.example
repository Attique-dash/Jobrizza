# MongoDB Connection (required for both Next.js and Flask)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/jobrizza?retryWrites=true&w=majority

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production

# Backend API URL (optional - only if using separate backend)
NEXT_PUBLIC_API_URL=http://localhost:5000

# External API Keys (for AI features)
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Email Configuration (optional - for email notifications)
RESEND_API_KEY=your-resend-api-key

# ==========================================
# Flask Backend Environment Variables
# ==========================================

# Flask settings
FLASK_ENV=development
FLASK_PORT=5000

# JWT Secret for Flask auth tokens (generate a strong random string)
JWT_SECRET=your-flask-jwt-secret-min-32-characters-long

# CORS origins (comma-separated for production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
